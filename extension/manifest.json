{
  "manifest_version": 3,
  "name": "StudySync",
  "version": "1.0.0",
  "description": "Your Second Brain For Learning. Highlight, summarize, and bookmark from any page.",
  "permissions": ["activeTab", "storage", "scripting", "contextMenus"],
  "action": { "default_popup": "popup.html", "default_title": "StudySync" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ],
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
}